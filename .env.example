# Throughline Studio — environment
# Copy to .env (gitignored). Only needed for the AI seam (/api/generate).

# Vercel AI Gateway key. Without it, /api/generate returns 503 and the app
# runs fine in offline mode (the suite tools still open via deep-link).
AI_GATEWAY_API_KEY=

# Optional model overrides (defaults: opus-4.8 primary, sonnet-4.6 fallback)
# TLS_MODEL=anthropic/claude-opus-4.8

# ── Login (Supabase) ────────────────────────────────────────────────
# Optional. Defaults to the shared research-suite Supabase project so login
# works out of the box and shares one account across the suite. Override to
# point at your own project. The anon key is public by design (RLS protects
# data). For OAuth/magic-link redirects to work, add this app's URL under
# Supabase → Authentication → URL Configuration → Redirect URLs.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
